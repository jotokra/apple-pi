{
  "name": "apple-pi-mobile-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Local HTTP bridge that exposes apple-pi pi sessions to the iOS app over HTTPS (LAN + NetBird). Phase 0 MVP.",
  "type": "module",
  "main": "bin/bridge.mjs",
  "bin": {
    "apple-pi-mobile-bridge": "bin/bridge.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node bin/bridge.mjs",
    "smoke": "bash ../smoke/run-mobile-bridge.sh"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/websocket": "^11.0.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.23.0"
  }
}
